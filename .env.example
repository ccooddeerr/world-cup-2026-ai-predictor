# OpenAI (required for live club match / WC forecasts with --no-mock)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.openai.com/v1
AI_USE_MOCK=true
AI_BLEND_WEIGHT=0.35

# Redis cache (optional — falls back to in-memory when unavailable)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
REDIS_KEY_PREFIX=wc2026-forecaster:
REDIS_CACHE_TTL_SEC=3600
